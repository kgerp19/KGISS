@model KGERP.Service.ServiceModel.ApplicationManageModel
@{
    ViewBag.Title = "Pending Approvals";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --primary: #4361ee;
        --primary-dark: #3a56d4;
        --primary-light: #eef1ff;
        --success: #2cb67d;
        --success-light: #e8f8f0;
        --danger: #e53e3e;
        --danger-light: #fef2f2;
        --warning: #f59e0b;
        --warning-light: #fffbeb;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 16px;
        --radius-xl: 20px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
        --shadow-md: 0 4px 14px rgba(0,0,0,0.08);
        --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .aml-wrapper {
        padding: 20px 0;
        font-family: inherit;
    }

    .aml-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 22px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .aml-topbar-left {
    }

    .aml-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--gray-400);
        margin-bottom: 4px;
    }

        .aml-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
        }

            .aml-breadcrumb a:hover {
                text-decoration: underline;
            }

        .aml-breadcrumb .sep {
            font-size: 9px;
        }

    .aml-topbar-left h2 {
        margin: 0;
        font-size: 22px;
        font-weight: 700;
        color: var(--gray-900);
        letter-spacing: -0.4px;
    }

    .aml-topbar-left p {
        margin: 3px 0 0;
        font-size: 13px;
        color: var(--gray-500);
    }

    .aml-btn-new {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fff;
        color: var(--primary);
        border: 1.5px solid var(--primary);
        border-radius: var(--radius-md);
        padding: 10px 22px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: var(--transition);
        white-space: nowrap;
    }

        .aml-btn-new:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
            color: var(--primary);
            text-decoration: none;
        }

        .aml-btn-new i {
            font-size: 13px;
        }

    .aml-card {
        background: #fff;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: var(--transition);
    }

        .aml-card:hover {
            box-shadow: var(--shadow-md);
        }

    .aml-table-wrapper {
        overflow-x: auto;
    }

    table.aml-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        min-width: 900px;
    }

        table.aml-table thead th {
            background: var(--gray-50);
            color: var(--gray-500);
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            padding: 13px 16px;
            border-bottom: 2px solid var(--gray-200);
            white-space: nowrap;
            text-align: left;
        }

            table.aml-table thead th:first-child {
                text-align: center;
                border-radius: 0;
            }

            table.aml-table thead th:last-child {
                text-align: center;
            }

        table.aml-table tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid var(--gray-100);
            color: var(--gray-700);
            vertical-align: middle;
        }

        table.aml-table tbody tr:last-child td {
            border-bottom: none;
        }

        table.aml-table tbody tr {
            transition: background 0.15s ease;
        }

            table.aml-table tbody tr:hover {
                background: var(--primary-light);
            }

    .aml-id-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--primary-light);
        color: var(--primary);
        font-weight: 700;
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 20px;
        min-width: 38px;
    }

    .aml-date-primary {
        font-weight: 500;
        color: var(--gray-800);
        white-space: nowrap;
        font-size: 13px;
    }

    .aml-date-sub {
        font-size: 12px;
        color: var(--gray-500);
        white-space: nowrap;
    }

    .aml-validity-range {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .aml-validity-dates {
        font-weight: 500;
        color: var(--gray-800);
        font-size: 12px;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .aml-validity-dates .arrow {
            color: var(--gray-400);
            font-size: 10px;
        }

    .aml-day-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: var(--gray-100);
        color: var(--gray-600);
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 10px;
        width: fit-content;
    }

    .aml-person-primary {
        font-weight: 600;
        color: var(--gray-800);
        font-size: 13px;
    }

    .aml-person-sub {
        font-size: 11px;
        color: var(--gray-500);
        margin-top: 1px;
    }

    .aml-reason-text {
        max-width: 200px;
        line-height: 1.5;
        color: var(--gray-600);
        font-size: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .aml-empty {
        text-align: center;
        padding: 60px 20px;
    }

    .aml-empty-icon {
        width: 56px;
        height: 56px;
        background: var(--success-light);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
    }

        .aml-empty-icon i {
            font-size: 26px;
            color: var(--success);
        }

    .aml-empty h5 {
        font-size: 15px;
        font-weight: 600;
        color: var(--gray-700);
        margin: 0 0 5px;
    }

    .aml-empty p {
        font-size: 13px;
        color: var(--gray-400);
        margin: 0;
    }

    .aml-btn-approve {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--success);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 7px 14px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        box-shadow: 0 2px 6px rgba(44,182,125,0.25);
    }

        .aml-btn-approve:hover {
            background: #239063;
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(44,182,125,0.35);
            color: #fff;
        }

    .aml-btn-reject {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--danger);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 7px 14px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        box-shadow: 0 2px 6px rgba(229,62,62,0.2);
    }

        .aml-btn-reject:hover {
            background: #b93333;
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(229,62,62,0.35);
            color: #fff;
        }

    .aml-action-group {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    /* Modal */
    .aml-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(17,24,39,0.55);
        z-index: 1050;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(2px);
        padding: 20px;
    }

        .aml-modal-overlay.open {
            display: flex;
            animation: fadeIn 0.2s ease;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            transform: translateY(16px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    .aml-modal {
        background: #fff;
        border-radius: var(--radius-xl);
        width: 100%;
        max-width: 500px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        overflow: hidden;
        animation: slideUp 0.25s ease;
    }

    .aml-modal-header {
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .aml-modal-header-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .aml-modal-header-icon {
        width: 38px;
        height: 38px;
        background: rgba(255,255,255,0.18);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .aml-modal-header-icon i {
            color: #fff;
            font-size: 16px;
        }

    .aml-modal-header h5 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
        color: #fff;
    }

    .aml-modal-header span {
        font-size: 12px;
        color: rgba(255,255,255,0.7);
        display: block;
        margin-top: 2px;
    }

    .aml-modal-close {
        width: 30px;
        height: 30px;
        background: rgba(255,255,255,0.15);
        border: none;
        border-radius: 50%;
        color: #fff;
        font-size: 15px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition);
        flex-shrink: 0;
    }

        .aml-modal-close:hover {
            background: rgba(255,255,255,0.3);
        }

    .aml-modal-body {
        padding: 24px;
    }

    .aml-modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--gray-100);
        display: flex;
        justify-content: flex-end;
        background: var(--gray-50);
    }

    .aml-btn-close-modal {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #fff;
        color: var(--gray-700);
        border: 1px solid var(--gray-300);
        border-radius: var(--radius-sm);
        padding: 8px 18px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
    }

        .aml-btn-close-modal:hover {
            background: var(--gray-50);
            color: var(--gray-900);
            border-color: var(--gray-400);
        }

    .aml-filter-group label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        color: var(--gray-500);
        display: block;
        margin-bottom: 6px;
    }

    .aml-filter-group .form-control {
        width: 100%;
        border: 1.5px solid var(--gray-200);
        border-radius: var(--radius-sm);
        padding: 10px 12px;
        font-size: 13px;
        color: var(--gray-800);
        background: #fff;
        transition: var(--transition);
    }

        .aml-filter-group .form-control:focus {
            border-color: var(--danger);
            box-shadow: 0 0 0 3px rgba(229,62,62,0.1);
            outline: none;
        }

    @@media (max-width: 640px) {
        .aml-topbar {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="aml-wrapper">
    <!-- Top Bar -->
    <div class="aml-topbar">
        <div class="aml-topbar-left">
            <div class="aml-breadcrumb">
                <a href="#"><i class="fa fa-home" style="font-size:11px"></i> Home</a>
                <span class="sep"><i class="fa fa-chevron-right"></i></span>
                <span>Applications</span>
                <span class="sep"><i class="fa fa-chevron-right"></i></span>
                <span>Pending Approvals</span>
            </div>
            <h2>Pending Credit Limit Approvals</h2>
            <p>Review and respond to pending credit limit requests</p>
        </div>
        <a href="@Url.Action("OrderCreditLimitManageList", "ApplicationManage", new { companyId = Model.CompanyId })" class="aml-btn-new">
            <i class="fa fa-list"></i> View All Applications
        </a>
    </div>

    <!-- Main Card -->
    <div class="aml-card">
        <div class="aml-table-wrapper">
            <table class="aml-table">
                <thead>
                    <tr>
                        <th style="text-align:center;width:56px;">ID</th>
                        <th>Apply date</th>
                        <th>Validity period</th>
                        <th>Applicant (Vendor)</th>
                        <th>Manager (Employee)</th>
                        <th>Reason</th>
                        <th style="text-align:center;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ApplicationList != null && Model.ApplicationList.Any())
                    {
                        foreach (var item in Model.ApplicationList)
                        {
                            var approvalStep = item.SignatoryApprovals.FirstOrDefault();

                            <tr>
                                <td style="text-align:center;"><span class="aml-id-badge">@item.ApplicationId</span></td>
                                <td>
                                    <div class="aml-date-primary">@item.ApplicationDate.ToString("dd MMM yyyy")</div>
                                    <div class="aml-date-sub">@item.ApplicationDate.ToString("dddd")</div>
                                </td>
                                <td>
                                    <div class="aml-validity-range">
                                        <div class="aml-validity-dates">
                                            @item.StartDate.ToString("dd MMM yyyy") <span class="arrow"><i class="fa fa-long-arrow-right"></i></span> @item.EndDate.ToString("dd MMM yyyy")
                                        </div>
                                        <span class="aml-day-pill"><i class="fa fa-clock-o" style="font-size:10px"></i> @item.DayCounts Days</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="aml-person-primary">@item.ApplicantName</div>
                                </td>
                                <td>
                                    <div class="aml-person-primary">@item.ManagerName</div>
                                </td>
                                <td><div class="aml-reason-text">@item.Reason</div></td>
                                <td style="text-align:center;">
                                    @if (approvalStep != null)
                                    {
                                        <div class="aml-action-group">
                                            <button class="aml-btn-approve" onclick="submitApproval(@approvalStep.RequisitionSignatoryApprovalId, 1)">
                                                <i class="fa fa-check"></i> Approve
                                            </button>
                                            <button class="aml-btn-reject" onclick="openRejectModal(@approvalStep.RequisitionSignatoryApprovalId)">
                                                <i class="fa fa-times"></i> Reject
                                            </button>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="aml-empty">
                                    <div class="aml-empty-icon"><i class="fa fa-check-circle"></i></div>
                                    <h5>All Caught Up!</h5>
                                    <p>No pending approvals require your attention at this time.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Reject Modal (Customized) -->
<div class="aml-modal-overlay" id="rejectModalOverlay">
    <div class="aml-modal" id="rejectModalBox">
        <div class="aml-modal-header" style="background: linear-gradient(135deg, var(--danger), #b92b27);">
            <div class="aml-modal-header-left">
                <div class="aml-modal-header-icon"><i class="fa fa-exclamation-triangle"></i></div>
                <div>
                    <h5>Reject Application</h5>
                    <span>Provide a reason for rejection (optional)</span>
                </div>
            </div>
            <button class="aml-modal-close" onclick="closeRejectModal()"><i class="fa fa-times"></i></button>
        </div>
        <div class="aml-modal-body bg-light">
            <input type="hidden" id="rejectApprovalId" />
            <div class="aml-filter-group" style="width: 100%;">
                <label>Reason for Rejection <span style="text-transform:none; font-weight:normal; color:#9ca3af;">(Optional)</span></label>
                <textarea id="rejectComment" class="form-control" rows="4" style="height: auto; min-height: 100px; resize: vertical;" placeholder="Briefly explain why this application is being rejected..."></textarea>
            </div>
        </div>
        <div class="aml-modal-footer">
            <button class="aml-btn-close-modal" onclick="closeRejectModal()">Cancel</button>
            <button class="aml-btn-reject" style="margin-left:8px;" id="btnConfirmReject" onclick="submitReject()"><i class="fa fa-times"></i> Confirm Reject</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openRejectModal(approvalId) {
            $('#rejectApprovalId').val(approvalId);
            $('#rejectComment').val('');
            $('#rejectModalOverlay').addClass('open');
        }

        function closeRejectModal() {
            $('#rejectModalOverlay').removeClass('open');
        }

        $('#rejectModalOverlay').on('click', function(e) {
            if (e.target === this) closeRejectModal();
        });

        function submitReject() {
            var approvalId = $('#rejectApprovalId').val();
            var comment = $('#rejectComment').val();

            // disable button to prevent double submit
            $('#btnConfirmReject').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Processing...');

            submitApproval(approvalId, 2, comment);
        }

        function submitApproval(approvalId, status, comment = "") {
            if (status == 1) { // Approve
                if (!confirm("Are you sure you want to officially APPROVE this application?")) {
                    return;
                }
            }

            $.ajax({
                url: '@Url.Action("UpdateApprovalStatus", "ApplicationManage")',
                type: 'POST',
                data: {
                    approvalId: approvalId,
                    status: status,
                    comment: comment
                },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error: " + res.message);
                        if(status == 2) {
                            $('#btnConfirmReject').prop('disabled', false).html('<i class="fa fa-times"></i> Confirm Reject');
                        }
                    }
                },
                error: function (err) {
                    alert("An error occurred while communicating with the server.");
                    console.error(err);
                    if(status == 2) {
                        $('#btnConfirmReject').prop('disabled', false).html('<i class="fa fa-times"></i> Confirm Reject');
                    }
                }
            });
        }
    </script>
}
