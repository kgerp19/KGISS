@model KGERP.Service.ServiceModel.ApplicationManageModel
@{
    ViewBag.Title = "Order Credit Limit Application";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── Base & Variables ── */
    :root {
        --primary: #4361ee;
        --primary-dark: #3a56d4;
        --primary-light: #eef1ff;
        --success: #2cb67d;
        --success-light: #e8f8f0;
        --danger: #e53e3e;
        --danger-light: #fef2f2;
        --warning: #f59e0b;
        --warning-light: #fffbeb;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 16px;
        --radius-xl: 20px;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
        --shadow-md: 0 4px 14px rgba(0,0,0,0.08);
        --shadow-lg: 0 10px 30px rgba(0,0,0,0.1);
        --shadow-xl: 0 20px 50px rgba(0,0,0,0.12);
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ── Page Wrapper ── */
    .ocl-page-wrapper {
        padding: 24px 0;
        min-height: 80vh;
    }

    /* ── Page Header ── */
    .ocl-page-header {
        margin-bottom: 28px;
    }

        .ocl-page-header h2 {
            font-size: 26px;
            font-weight: 700;
            color: var(--gray-900);
            margin: 0;
            letter-spacing: -0.5px;
        }

        .ocl-page-header p {
            font-size: 14px;
            color: var(--gray-500);
            margin: 4px 0 0 0;
        }

    .ocl-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--gray-400);
        margin-bottom: 8px;
    }

        .ocl-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
        }

            .ocl-breadcrumb a:hover {
                text-decoration: underline;
            }

        .ocl-breadcrumb i {
            font-size: 10px;
        }

    /* ── Main Card ── */
    .ocl-card {
        background: #ffffff;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-xl);
        overflow: hidden;
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
    }

        .ocl-card:hover {
            box-shadow: var(--shadow-md);
        }

    .ocl-card-header {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        padding: 22px 28px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .ocl-card-header-icon {
        width: 44px;
        height: 44px;
        background: rgba(255,255,255,0.2);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
    }

        .ocl-card-header-icon i {
            color: #ffffff;
            font-size: 20px;
        }

    .ocl-card-header-text h4 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
        color: #ffffff;
        letter-spacing: -0.3px;
    }

    .ocl-card-header-text span {
        font-size: 12px;
        color: rgba(255,255,255,0.75);
        margin-top: 2px;
        display: block;
    }

    .ocl-card-body {
        padding: 28px;
    }

    /* ── Alert Messages ── */
    .ocl-alert {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 14px 18px;
        border-radius: var(--radius-md);
        margin-bottom: 24px;
        font-size: 14px;
        font-weight: 500;
        border: 1px solid transparent;
        animation: oclSlideDown 0.4s ease-out;
    }

    .ocl-alert-success {
        background: var(--success-light);
        border-color: rgba(44,182,125,0.2);
        color: #065f46;
    }

    .ocl-alert-danger {
        background: var(--danger-light);
        border-color: rgba(229,62,62,0.2);
        color: #991b1b;
    }

    .ocl-alert .ocl-alert-icon {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .ocl-alert-success .ocl-alert-icon {
        background: var(--success);
        color: #fff;
    }

    .ocl-alert-danger .ocl-alert-icon {
        background: var(--danger);
        color: #fff;
    }

    .ocl-alert .ocl-alert-icon i {
        font-size: 10px;
    }

    .ocl-alert .close {
        margin-left: auto;
        background: none;
        border: none;
        font-size: 18px;
        cursor: pointer;
        opacity: 0.5;
        line-height: 1;
        padding: 0;
        color: inherit;
    }

        .ocl-alert .close:hover {
            opacity: 1;
        }

    @@keyframes oclSlideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Form Section ── */
    .ocl-section-label {
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: var(--gray-400);
        margin-bottom: 18px;
        padding-bottom: 10px;
        border-bottom: 2px solid var(--gray-100);
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .ocl-section-label i {
            color: var(--primary);
            font-size: 14px;
        }

    .ocl-form-group {
        margin-bottom: 22px;
    }

        .ocl-form-group label,
        .ocl-form-group .control-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 6px;
            letter-spacing: 0.1px;
        }

            .ocl-form-group label .ocl-required {
                color: var(--danger);
                margin-left: 2px;
            }

        .ocl-form-group .form-control {
            border: 1.5px solid var(--gray-200);
            border-radius: var(--radius-sm);
            padding: 10px 14px;
            font-size: 14px;
            color: var(--gray-800);
            background: var(--gray-50);
            transition: var(--transition);
            height: auto;
        }

            .ocl-form-group .form-control:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(67,97,238,0.12);
                background: #ffffff;
                outline: none;
            }

            .ocl-form-group .form-control::placeholder {
                color: var(--gray-400);
                font-size: 13px;
            }

        .ocl-form-group textarea.form-control {
            resize: vertical;
            min-height: 90px;
        }

        .ocl-form-group .input-group {
            position: relative;
        }

            .ocl-form-group .input-group .input-group-prepend .input-group-text {
                background: var(--gray-100);
                border: 1.5px solid var(--gray-200);
                border-right: none;
                border-radius: var(--radius-sm) 0 0 var(--radius-sm);
                color: var(--gray-500);
                font-size: 14px;
                padding: 10px 12px;
            }

            .ocl-form-group .input-group .form-control {
                border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            }

        .ocl-form-group .text-danger {
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        /* Select2 Overrides */
        .ocl-form-group .select2-container--bootstrap .select2-selection {
            border: 1.5px solid var(--gray-200) !important;
            border-radius: var(--radius-sm) !important;
            background: var(--gray-50) !important;
            padding: 6px 10px !important;
            height: auto !important;
            min-height: 42px !important;
            transition: var(--transition);
        }

        .ocl-form-group .select2-container--bootstrap.select2-container--focus .select2-selection,
        .ocl-form-group .select2-container--bootstrap.select2-container--open .select2-selection {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(67,97,238,0.12) !important;
            background: #ffffff !important;
        }

    /* ── Submit Button ── */
    .ocl-submit-section {
        margin-top: 8px;
        padding-top: 24px;
        border-top: 2px solid var(--gray-100);
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 12px;
    }

    .ocl-btn-submit {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient(135deg, var(--success), #229c6b);
        color: #ffffff;
        border: none;
        border-radius: var(--radius-md);
        padding: 12px 32px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        box-shadow: 0 4px 14px rgba(44,182,125,0.3);
        letter-spacing: 0.2px;
    }

        .ocl-btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(44,182,125,0.4);
            background: linear-gradient(135deg, #229c6b, #1e8f60);
            color: #ffffff;
            text-decoration: none;
        }

        .ocl-btn-submit:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(44,182,125,0.3);
        }

        .ocl-btn-submit i {
            font-size: 14px;
        }

    .ocl-submit-hint {
        font-size: 12px;
        color: var(--gray-400);
    }

    /* ── Status Result Card ── */
    .ocl-result-card {
        background: #ffffff;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        margin-top: 28px;
        transition: var(--transition);
    }

        .ocl-result-card:hover {
            box-shadow: var(--shadow-md);
        }

    .ocl-result-header {
        background: linear-gradient(135deg, var(--success), #229c6b);
        padding: 22px 28px;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .ocl-result-header-icon {
        width: 44px;
        height: 44px;
        background: rgba(255,255,255,0.2);
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(10px);
    }

        .ocl-result-header-icon i {
            color: #fff;
            font-size: 20px;
        }

    .ocl-result-header-text h4 {
        margin: 0;
        color: #fff;
        font-size: 18px;
        font-weight: 600;
    }

    .ocl-result-header-text span {
        font-size: 12px;
        color: rgba(255,255,255,0.75);
        display: block;
        margin-top: 2px;
    }

    .ocl-result-body {
        padding: 28px;
    }

    /* ── Table ── */
    .ocl-table-wrapper {
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .ocl-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .ocl-table thead th {
            background: var(--gray-50);
            color: var(--gray-600);
            font-weight: 600;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            padding: 14px 16px;
            border-bottom: 2px solid var(--gray-200);
            white-space: nowrap;
            text-align: left;
        }

            .ocl-table thead th:first-child {
                text-align: center;
            }

        .ocl-table tbody td {
            padding: 14px 16px;
            border-bottom: 1px solid var(--gray-100);
            color: var(--gray-700);
            vertical-align: top;
        }

        .ocl-table tbody tr:last-child td {
            border-bottom: none;
        }

        .ocl-table tbody tr:hover {
            background: var(--primary-light);
        }

        .ocl-table tbody tr {
            transition: background 0.2s ease;
        }

    .ocl-app-id {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--primary-light);
        color: var(--primary);
        font-weight: 700;
        font-size: 13px;
        padding: 4px 12px;
        border-radius: 20px;
        min-width: 40px;
    }

    .ocl-date-cell {
        white-space: nowrap;
        font-size: 13px;
    }

    .ocl-days-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--gray-100);
        color: var(--gray-700);
        font-weight: 600;
        font-size: 13px;
        padding: 4px 10px;
        border-radius: 20px;
        min-width: 36px;
    }

    .ocl-person-cell {
        font-weight: 500;
        color: var(--gray-800);
    }

    .ocl-reason-cell {
        max-width: 200px;
        line-height: 1.5;
        color: var(--gray-600);
    }

    /* ── Signatory Flow ── */
    .ocl-signatory-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .ocl-signatory-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 8px 0;
        position: relative;
    }

        .ocl-signatory-item:not(:last-child) {
            border-bottom: 1px dashed var(--gray-200);
        }

    .ocl-sig-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 5px;
    }

        .ocl-sig-dot.dot-success {
            background: var(--success);
            box-shadow: 0 0 0 3px rgba(44,182,125,0.2);
        }

        .ocl-sig-dot.dot-danger {
            background: var(--danger);
            box-shadow: 0 0 0 3px rgba(229,62,62,0.2);
        }

        .ocl-sig-dot.dot-warning {
            background: var(--warning);
            box-shadow: 0 0 0 3px rgba(245,158,11,0.2);
        }

    .ocl-sig-info {
        flex: 1;
        min-width: 0;
    }

    .ocl-sig-name {
        font-weight: 600;
        color: var(--gray-800);
        font-size: 13px;
    }

    .ocl-sig-designation {
        font-size: 11px;
        color: var(--gray-400);
        margin-left: 4px;
    }

    .ocl-sig-status {
        font-size: 11px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 10px;
        display: inline-block;
        margin-top: 2px;
    }

        .ocl-sig-status.sig-approved {
            background: var(--success-light);
            color: #065f46;
        }

        .ocl-sig-status.sig-rejected {
            background: var(--danger-light);
            color: #991b1b;
        }

        .ocl-sig-status.sig-pending {
            background: var(--warning-light);
            color: #92400e;
        }

    .ocl-sig-comment {
        font-size: 12px;
        color: var(--gray-500);
        margin-top: 4px;
        font-style: italic;
        display: flex;
        align-items: flex-start;
        gap: 4px;
    }

        .ocl-sig-comment i {
            margin-top: 2px;
            color: var(--gray-400);
        }

    /* ── Status Badges ── */
    .status-badge {
        font-weight: 600;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 12px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        letter-spacing: 0.3px;
        white-space: nowrap;
    }

    .status-pending {
        background: var(--warning-light);
        color: #92400e;
        border: 1px solid rgba(245,158,11,0.25);
    }

    .status-approved {
        background: var(--success-light);
        color: #065f46;
        border: 1px solid rgba(44,182,125,0.25);
    }

    .status-rejected {
        background: var(--danger-light);
        color: #991b1b;
        border: 1px solid rgba(229,62,62,0.25);
    }

    /* ── View All Button ── */
    .ocl-view-all-section {
        margin-top: 24px;
        text-align: center;
    }

    .ocl-btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 2px solid var(--primary);
        color: var(--primary);
        background: transparent;
        border-radius: var(--radius-md);
        padding: 10px 28px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: var(--transition);
    }

        .ocl-btn-outline:hover {
            background: var(--primary);
            color: #ffffff;
            text-decoration: none;
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(67,97,238,0.3);
        }

    /* ── Form Row Grid ── */
    .ocl-form-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .ocl-form-row-full {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
    }

    /* ── Responsive ── */
    @@media (max-width: 992px) {
        .ocl-form-row {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 576px) {
        .ocl-form-row {
            grid-template-columns: 1fr;
        }

        .ocl-card-body,
        .ocl-result-body {
            padding: 18px;
        }

        .ocl-card-header,
        .ocl-result-header {
            padding: 16px 18px;
        }

        .ocl-submit-section {
            flex-direction: column;
            align-items: stretch;
        }

        .ocl-btn-submit {
            justify-content: center;
        }

        .ocl-submit-hint {
            text-align: center;
        }
    }
</style>

<div class="ocl-page-wrapper">
    <!-- Page Header -->
    <div class="ocl-page-header">
        <div class="ocl-breadcrumb">
            <a href="@Url.Action("Index", "Home")"><i class="fa fa-home"></i> Home</a>
            <i class="fa fa-chevron-right"></i>
            <span>Order Credit Limit Application</span>
        </div>
        <h4>Order Credit Limit Application</h4>
        <p>Submit a new credit limit request for order processing approval</p>
    </div>
    @if (Model.ApplicationId <= 0 && !Model.ApplicationList.Any())
    {
        <!-- Create Application Card -->
        <div class="ocl-card">
            <div class="ocl-card-header">
                <div class="ocl-card-header-icon">
                    <i class="fa fa-plus-circle"></i>
                </div>
                <div class="ocl-card-header-text">
                    <h4>New Application</h4>
                    <span>Fill in the details below to submit your request</span>
                </div>
            </div>
            <div class="ocl-card-body">
                @if (TempData["Message"] != null)
                {
                    <div class="ocl-alert ocl-alert-success alert" role="alert">
                        <div class="ocl-alert-icon"><i class="fa fa-check"></i></div>
                        <span>@TempData["Message"]</span>
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="ocl-alert ocl-alert-danger alert" role="alert">
                        <div class="ocl-alert-icon"><i class="fa fa-exclamation"></i></div>
                        <span>@TempData["ErrorMessage"]</span>
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                }

                @using (Html.BeginForm("OrderCreditLimitEntry", "ApplicationManage", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.CompanyId)

                    <!-- Date & Selection Fields -->
                    <div class="ocl-section-label">
                        <i class="fa fa-calendar-o"></i> Application Details
                    </div>

                    <div class="row">
                        <div class="col-md-3">
                            <div class="ocl-form-group">
                                @Html.LabelFor(m => m.StartDate, new { @class = "control-label" })
                                <div class="input-group">
                                    <div class="input-group-addon">
                                        <i class="fa fa-calendar"></i>
                                    </div>
                                    @Html.EditorFor(m => m.StartDate, new { htmlAttributes = new { @class = "form-control", @type = "date", required = "required", @style = "padding: 1%;padding-left: 5%;" } })
                                </div>
                                @Html.ValidationMessageFor(m => m.StartDate, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="ocl-form-group">
                                @Html.LabelFor(m => m.EndDate, new { @class = "control-label" })
                                <div class="input-group">
                                    <div class="input-group-addon">
                                        <i class="fa fa-calendar"></i>
                                    </div>
                                    @Html.EditorFor(m => m.EndDate, new { htmlAttributes = new { @class = "form-control", @type = "date", required = "required", @style = "padding: 1%;padding-left: 5%;" } })
                                </div>
                                @Html.ValidationMessageFor(m => m.EndDate, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="ocl-form-group w-100">
                                @Html.LabelFor(m => m.ManagerId, new { @class = "control-label" })
                                @Html.DropDownListFor(m => m.ManagerId, Model.Managers, "Select Manager...", new { @class = "form-control select2", required = "required", style = "width:100%" })
                                @Html.ValidationMessageFor(m => m.ManagerId, "", new { @class = "text-danger" })
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="ocl-form-group w-100">
                                @Html.LabelFor(m => m.ApplicantId, new { @class = "control-label" })
                                @Html.DropDownListFor(m => m.ApplicantId, Model.Applicants, "Select Applicant...", new { @class = "form-control select2", required = "required", style = "width:100%" })
                                @Html.ValidationMessageFor(m => m.ApplicantId, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>

                    <!-- Reason Section -->
                    <div class="ocl-section-label" style="margin-top: 8px;">
                        <i class="fa fa-align-left"></i> Justification
                    </div>

                    <div class="ocl-form-row-full">
                        <div class="ocl-form-group">
                            @Html.LabelFor(m => m.Reason, new { @class = "control-label" })
                            @Html.TextAreaFor(m => m.Reason, new { @class = "form-control", rows = "3", placeholder = "Provide a clear and detailed reason for this credit limit application...", required = "required" })
                            @Html.ValidationMessageFor(m => m.Reason, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="ocl-submit-section">
                        <span class="ocl-submit-hint"><i class="fa fa-info-circle"></i> All fields are required</span>
                        <button type="submit" class="ocl-btn-submit">
                            <i class="fa fa-paper-plane"></i> Submit Application
                        </button>
                    </div>
                }
            </div>
        </div>
    }
    <!-- Status Result Section -->
    @if (Model.ApplicationId > 0 && Model.ApplicationList != null && Model.ApplicationList.Any())
    {
        <div class="ocl-result-card">
            <div class="ocl-result-header">
                <div class="ocl-result-header-icon">
                    <i class="fa fa-check-square-o"></i>
                </div>
                <div class="ocl-result-header-text">
                    <h4>Application Submitted Successfully</h4>
                    <span>Review the application details and approval workflow below</span>
                </div>
            </div>
            <div class="ocl-result-body">
                <div class="ocl-table-wrapper">
                    <div class="table-responsive">
                        <table class="ocl-table">
                            <thead>
                                <tr>
                                    <th style="text-align:center;">ID</th>
                                    <th>Date</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th style="text-align:center;">Days</th>
                                    <th>Applicant</th>
                                    <th>Manager</th>
                                    <th>Reason</th>
                                    <th>Signatory Flow</th>
                                    <th style="text-align:center;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ApplicationList)
                                {
                                    <tr>
                                        <td style="text-align:center;">
                                            <span class="ocl-app-id">@item.ApplicationId</span>
                                        </td>
                                        <td class="ocl-date-cell">@item.ApplicationDate.ToString("dd-MMM-yyyy")</td>
                                        <td class="ocl-date-cell">@item.StartDate.ToString("dd-MMM-yyyy")</td>
                                        <td class="ocl-date-cell">@item.EndDate.ToString("dd-MMM-yyyy")</td>
                                        <td style="text-align:center;">
                                            <span class="ocl-days-badge">@item.DayCounts</span>
                                        </td>
                                        <td class="ocl-person-cell">@item.ApplicantName</td>
                                        <td class="ocl-person-cell">@item.ManagerName</td>
                                        <td class="ocl-reason-cell">@item.Reason</td>
                                        <td>
                                            @if (item.SignatoryApprovals != null && item.SignatoryApprovals.Any())
                                            {
                                                <ul class="ocl-signatory-list">
                                                    @foreach (var sig in item.SignatoryApprovals)
                                                    {
                                                        string dotClass = sig.Status == 1 ? "dot-success" : (sig.Status == 2 ? "dot-danger" : "dot-warning");
                                                        string statusClass = sig.Status == 1 ? "sig-approved" : (sig.Status == 2 ? "sig-rejected" : "sig-pending");
                                                        <li class="ocl-signatory-item">
                                                            <span class="ocl-sig-dot @dotClass"></span>
                                                            <div class="ocl-sig-info">
                                                                <span class="ocl-sig-name">@sig.EmployeeName</span>
                                                                <span class="ocl-sig-designation">@sig.DesignationName</span>
                                                                <br />
                                                                <span class="ocl-sig-status @statusClass">@sig.StatusName</span>
                                                                @if (!string.IsNullOrEmpty(sig.Comment))
                                                                {
                                                                    <div class="ocl-sig-comment">
                                                                        <i class="fa fa-comment-o"></i> @sig.Comment
                                                                    </div>
                                                                }
                                                            </div>
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                        </td>
                                        <td style="text-align:center;">
                                            @if (item.Status == 1)
                                            {
                                                <span class="status-badge status-approved">
                                                    <i class="fa fa-check-circle"></i> Approved
                                                </span>
                                            }
                                            else if (item.Status == 2)
                                            {
                                                <span class="status-badge status-rejected">
                                                    <i class="fa fa-times-circle"></i> Rejected
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-pending">
                                                    <i class="fa fa-clock-o"></i> Pending
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="ocl-view-all-section">
                    <a href="@Url.Action("OrderCreditLimitManageList", "ApplicationManage", new { companyId = Model.CompanyId })" class="ocl-btn-outline">
                        <i class="fa fa-list-ul"></i> View All Applications
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>$(document).ready(function () {
            // Fix jQuery MVC Date Validation issue with HTML5 date inputs
            if ($.validator) {
                $.validator.methods.date = function(value, element) {
                    return this.optional(element) || !/Invalid|NaN/.test(new Date(value).toString());
                };
            }

            // Apply select2 to dropdowns
            if ($.fn.select2) {
                $('.select2').select2({
                    theme: "bootstrap",
                    width: '100%'
                });

                // Apply custom margin after Select2 is initialized
                $('#select2-ApplicantId-container').css('margin-top', '1%');
                $('#select2-ManagerId-container').css('margin-top', '1%');
            }

            // Close alerts automatically after a bit
            window.setTimeout(function () {
                $(".alert").fadeTo(500, 0).slideUp(500, function () {
                    $(this).remove();
                });
            }, 4000);
        });</script>
}