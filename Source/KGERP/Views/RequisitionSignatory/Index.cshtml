<section class="content-header">
    <h1>
        <i class="fa fa-users"></i> Approval Configuration
        <small>Manage signatory approval process</small>
    </h1>
</section>

<section class="content">
    <input id="hdnCompanyId" value="@ViewBag.CompanyId" hidden />
    <div class="box box-primary">
        <div class="box-header with-border">
            <h3 class="box-title">Approval Process Signatory System</h3>
        </div>

        <div class="box-body">
            <!-- Module Name Selection -->
            <div class="row">
                <div class="col-md-12">
                    <div class="form-group">
                        <label for="ddlModuleName">Module Name</label>
                        @Html.DropDownList("ddlModuleName",
                            new SelectList(Model.ModelNames, "Value", "Text"),
                            "-- Select Module --",
                            new { @class = "form-control", id = "ddlModuleName" })
                    </div>
                </div>
            </div>

            <!-- Configuration For Section -->
            <div class="config-section">
                <div class="section-header">
                    <h4>Configuration For</h4>
                </div>
                <div class="section-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="ddlEmployee">Employee <span class="text-danger">*</span></label>
                                <select id="ddlEmployee" class="form-control">
                                    <option value="">-- Select Employee --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="ddlCompany">Applicant Company</label>
                                @Html.DropDownList("ddlCompany",
                                    new SelectList(Model.Companies, "Value", "Text"),
                                    "-- Select Company --",
                                    new { @class = "form-control", id = "ddlCompany" })
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="ddlDepartment">Applicant Department</label>
                                <select id="ddlDepartment" class="form-control">
                                    <option value="">-- Select Department --</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="ddlDesignation">Applicant Designation</label>
                                <select id="ddlDesignation" class="form-control">
                                    <option value="">-- Select Designation --</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Approvers Section -->
            <div class="approvers-section">
                <div class="section-header">
                    <h4>Approvers</h4>
                    <div class="header-actions">
                        <button type="button" class="btn btn-warning btn-sm" id="btnReplaceApprover">
                            <i class="fa fa-exchange"></i> Replace Approver
                        </button>
                    </div>
                </div>
                <div class="section-body">
                    <div class="table-controls">
                        <button type="button" class="btn btn-success btn-sm" id="btnAddNew">
                            <i class="fa fa-plus"></i> Add New
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table id="tblSignatories" class="table table-bordered table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Employee</th>
                                    <th>Company</th>
                                    <th>Department</th>
                                    <th>Designation</th>
                                    <th>Approver</th>
                                    <th>Level</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create/Edit Modal Placeholder -->
<div id="modalCreateEdit"></div>

<!-- Replace Approver Modal Placeholder -->
<div id="modalReplaceApprover"></div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="modalDelete" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">Confirm Delete</h4>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this signatory?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDelete">Delete</button>
            </div>
        </div>
    </div>
</div>
@section Styles {
    <link href="~/Content/RequisitionSignatory.css" rel="stylesheet" />
    <style>
        /* Fix autocomplete dropdown z-index to appear above modal */
        .ui-autocomplete {
            z-index: 9999 !important;
            max-height: 200px;
            overflow-y: auto;
            overflow-x: hidden;
        }
    </style>
}

@section Scripts {
    <script src="~/Scripts/RequisitionSignatory.js"></script>
}
