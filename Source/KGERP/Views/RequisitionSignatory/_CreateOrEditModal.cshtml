                                        <option value="2">2</option>
                                        <option value="3">3</option>
                                        <option value="4">4</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>-->

                    <!-- COMMON FIELDS -->
                    <div class="row">
                        @if (string.IsNullOrEmpty(Model.IntegrateWith))
                        {
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="ddlModalIntegrateWith">Module Name <span class="text-danger">*</span></label>
                                    @Html.DropDownListFor(m => m.IntegrateWith,
                                        new SelectList(Model.ModelNames, "Value", "Text", Model.IntegrateWith),
                                        "-- Select Module --",
                                        new { @class = "form-control", id = "ddlModalIntegrateWith" })
                                    @Html.ValidationMessageFor(m => m.IntegrateWith, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        }
                        <div class="col-md-6" style="margin-top:1%">
                            <div class="form-group">
                                <div class="checkbox">
                                    <label>
                                        @Html.CheckBoxFor(m => m.IsHRAdmin, new { id = "chkIsHRAdmin" })
                                        Is Supreme Power
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="btnSaveSignatory">
                        <i class="fa fa-save"></i> Save
                    </button>
                </div>
            }
        </div>
    </div>
</div>

