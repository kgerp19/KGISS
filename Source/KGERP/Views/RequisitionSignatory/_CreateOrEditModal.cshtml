                            <!--<div class="col-md-4">
                                <div class="form-group">
                                    <label for="ddlBulkDesignation">Designation</label>
                                    <select id="ddlBulkDesignation" name="BulkDesignationId" class="form-control">
                                        <option value="">-- All Designations --</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <button type="button" class="btn btn-info btn-sm" id="btnPreviewEmployees">
                                    <i class="fa fa-eye"></i> Preview Affected Employees
                                </button>
                                <div id="employeePreview" class="mt-2" style="display: none;">
                                    <div class="alert alert-warning">
                                        <strong>Affected Employees:</strong> <span id="employeeCount">0</span> employee(s) will be assigned this signatory.
                                        <div id="employeeList" style="max-height: 150px; overflow-y: auto; margin-top: 10px;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">-->
                            <!-- Signatory Selection (Bulk) -->
                            <!--<div class="col-md-6">
                                <div class="form-group">
                                    <label for="txtBulkSignatory">Signatory/Approver <span class="text-danger">*</span></label>
                                    <input type="text" id="txtBulkSignatory" class="form-control" placeholder="Type to search signatory..." />
                                    <input type="hidden" id="hdnBulkSignatoryEmpId" name="BulkSignatoryEmpId" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="ddlBulkOrderBy">Level <span class="text-danger">*</span></label>
                                    <select id="ddlBulkOrderBy" name="BulkOrderBy" class="form-control">
