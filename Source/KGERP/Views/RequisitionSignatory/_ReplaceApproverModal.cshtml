

@model KGERP.Data.CustomModel.ReplaceApproverViewModel

<div class="modal fade" id="modalReplaceApproverMain" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            @using (Html.BeginForm("ReplaceApprover", "RequisitionSignatory", FormMethod.Post, new { id = "formReplaceApprover" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.IntegrateWith)
                @Html.HiddenFor(m => m.CompanyId)

                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h4 class="modal-title">Replace Approver</h4>
                </div>

                <div class="modal-body">
                    <div class="row">
                        <!-- FROM Section -->
                        <div class="col-md-6">
                            <div class="replace-section from-section">
                                <h5 class="section-title">From</h5>

                                <div class="form-group">
                                    <label>Code <span class="text-danger">*</span></label>
                                    <input type="text" id="txtFromEmployee" class="form-control" placeholder="Type to search..." />
                                    @Html.HiddenFor(m => m.OldSignatoryEmpId, new { id = "hdnOldSignatoryEmpId" })
                                    @Html.ValidationMessageFor(m => m.OldSignatoryEmpId, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    <label>Company</label>
                                    <input type="text" id="txtFromCompany" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Department</label>
                                    <input type="text" id="txtFromDepartment" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Designation</label>
                                    <input type="text" id="txtFromDesignation" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Appointment Date</label>
                                    <input type="text" id="txtFromAppointmentDate" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Employee Status</label>
                                    <div class="employee-status" id="divFromStatus">
                                        <span class="status-badge"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- TO Section -->
                        <div class="col-md-6">
                            <div class="replace-section to-section">
                                <h5 class="section-title">To</h5>

                                <div class="form-group">
                                    <label>Code <span class="text-danger">*</span></label>
                                    <input type="text" id="txtToEmployee" class="form-control" placeholder="Type to search..." />
                                    @Html.HiddenFor(m => m.NewSignatoryEmpId, new { id = "hdnNewSignatoryEmpId" })
                                    @Html.ValidationMessageFor(m => m.NewSignatoryEmpId, "", new { @class = "text-danger" })
                                </div>

                                <div class="form-group">
                                    <label>Company</label>
                                    <input type="text" id="txtToCompany" class="form-control" readonly />
                                </div>


                                <div class="form-group">
                                    <label>Department</label>
                                    <input type="text" id="txtToDepartment" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Designation</label>
                                    <input type="text" id="txtToDesignation" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Appointment Date</label>
                                    <input type="text" id="txtToAppointmentDate" class="form-control" readonly />
                                </div>

                                <div class="form-group">
                                    <label>Employee Status</label>
                                    <div class="employee-status" id="divToStatus">
                                        <span class="status-badge"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success" id="btnConfirmReplace">
                        <i class="fa fa-exchange"></i> Replace Approver
                    </button>
                </div>
            }
        </div>
    </div>
</div>
